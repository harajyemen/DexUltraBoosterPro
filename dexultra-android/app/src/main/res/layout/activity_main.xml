<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="56dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DexUltra"
                    android:textColor="@color/accent"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvShizukuStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ Shizuku"
                    android:textColor="@color/warning"
                    android:textSize="11sp"
                    android:paddingEnd="8dp" />

                <Button
                    android:id="@+id/btnConnectShizuku"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="ربط"
                    android:textSize="11sp"
                    android:visibility="gone"
                    style="@style/DexButton.Outlined" />
            </LinearLayout>

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    style="@style/DexCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RAM"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tvRamValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/accent"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    style="@style/DexCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="حرارة"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tvTempValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/warning"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- BOOST BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBoost"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:text="🚀 تعزيز الأداء"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark"
                app:backgroundTint="@color/accent"
                app:cornerRadius="20dp"
                android:layout_marginBottom="12dp" />

            <!-- Status Text -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="جاهز للتعزيز"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingBottom="16dp" />

            <!-- Overlay Toggle Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/DexCard">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎯 ماشر الصندوق (Crosshair)"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="عائم فوق اللعبة، قابل للسحب"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchOverlay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/accent"
                        app:trackTint="@color/primary_light" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- File Injection Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/DexCard">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💉 حقن ملفات FPS"
                        android:textColor="@color/accent"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingBottom="8dp" />

                    <!-- PUBG Version -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="إصدار اللعبة:"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:paddingBottom="4dp" />

                    <Spinner
                        android:id="@+id/spinnerPubgVersion"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@color/surface_elevated"
                        android:padding="8dp"
                        android:textColor="@color/text_primary" />

                    <Space android:layout_width="match_parent" android:layout_height="8dp" />

                    <!-- FPS Selection Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎮 معدل الإطارات: "
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <Spinner
                            android:id="@+id/spinnerFps"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@color/surface_elevated"
                            android:padding="4dp"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <Space android:layout_width="match_parent" android:layout_height="8dp" />

                    <Button
                        android:id="@+id/btnInjectFiles"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="💉 حقن UserCustom.ini + Active.sav"
                        android:textSize="13sp"
                        android:textAllCaps="false"
                        style="@style/DexButton.Primary" />

                    <TextView
                        android:id="@+id/tvInjectStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/success"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:paddingTop="6dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:background="@color/surface"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
